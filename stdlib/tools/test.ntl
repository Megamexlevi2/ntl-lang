*// ntl:test — built-in test runner with suites, assertions, and pretty output
*// Usage: import { suite } from "ntl:test"  then suite("Name", s => { s.test("...", t => { t.equal(a, b) }) })

fn colorize(color, s) {
  if (!process.stdout.isTTY) { return s }
  val codes = { green: 32, red: 31, yellow: 33, cyan: 36, gray: 90, bold: 1, reset: 0 }
  return `\x1b[${codes[color] || 0}m${s}\x1b[0m`
}

*// AssertError — thrown when an assertion fails; carries expected vs actual
class AssertError extends Error {
  constructor(message, expected, actual) {
    super(message)
    this.name     = "AssertError"
    this.expected = expected
    this.actual   = actual
  }
}

*// deepEqual — recursively compare two values
fn deepEqual(a, b) {
  if (a === b) { return true }
  if (a === null || b === null) { return false }
  if (typeof a !== typeof b) { return false }
  if (typeof a !== "object") { return false }
  if (Array.isArray(a) !== Array.isArray(b)) { return false }
  val ak = Object.keys(a)
  val bk = Object.keys(b)
  if (ak.length !== bk.length) { return false }
  return ak.every(k => deepEqual(a[k], b[k]))
}

*// ─── Individual assertion functions ──────────────────────────────────

fn _equal(actual, expected, message) {
  if (actual !== expected) {
    raise new AssertError(message || `Expected ${JSON.stringify(expected)}, got ${JSON.stringify(actual)}`, expected, actual)
  }
}

fn _notEqual(actual, expected, message) {
  if (actual === expected) {
    raise new AssertError(message || `Expected values to differ`, `not ${JSON.stringify(expected)}`, actual)
  }
}

fn _deepEqual(actual, expected, message) {
  if (!deepEqual(actual, expected)) {
    val exp = JSON.stringify(expected, null, 2)
    val got = JSON.stringify(actual, null, 2)
    raise new AssertError(message || `Deep equal failed\n  Expected: ${exp}\n  Got:      ${got}`, expected, actual)
  }
}

fn _ok(value, message) {
  if (!value) {
    raise new AssertError(message || `Expected truthy value, got ${JSON.stringify(value)}`, true, value)
  }
}

fn _notOk(value, message) {
  if (value) {
    raise new AssertError(message || `Expected falsy value, got ${JSON.stringify(value)}`, false, value)
  }
}

fn _throws(fn2, message) {
  var threw = false
  try { fn2() } catch (_e) { threw = true }
  if (!threw) {
    raise new AssertError(message || "Expected function to raise", "throws", "did not raise")
  }
}

async fn _rejects(fn2, message) {
  var threw = false
  try { await fn2() } catch (_e) { threw = true }
  if (!threw) {
    raise new AssertError(message || "Expected async to reject", "rejects", "did not reject")
  }
}

fn _includes(haystack, needle, message) {
  val found = Array.isArray(haystack)
    ? haystack.includes(needle)
    : String(haystack).includes(String(needle))
  if (!found) {
    raise new AssertError(message || `Expected to include ${JSON.stringify(needle)}`, needle, haystack)
  }
}

fn _match(str, regex, message) {
  if (!regex.test(String(str))) {
    raise new AssertError(message || `Expected "${str}" to match ${regex}`, regex, str)
  }
}

fn _closeTo(actual, expected, delta, message) {
  val diff = Math.abs(actual - expected)
  if (diff > (delta || 0.001)) {
    raise new AssertError(message || `Expected ${actual} to be close to ${expected} (±${delta || 0.001})`, expected, actual)
  }
}

fn _type(value, typeName, message) {
  if (typeof value !== typeName) {
    raise new AssertError(message || `Expected type "${typeName}", got "${typeof value}"`, typeName, typeof value)
  }
}

*// assert object — this is what you get as `t` in your test functions
val assert = {
  equal:     _equal,
  notEqual:  _notEqual,
  deepEqual: _deepEqual,
  ok:        _ok,
  notOk:     _notOk,
  throws:    _throws,
  rejects:   _rejects,
  includes:  _includes,
  match:     _match,
  type:      _type,
  closeTo:   _closeTo
}

*// ─── Suite / Test runner ──────────────────────────────────────────────

*// Global registry of suites — filled as suite() is called
val _suites = []
var _running = false

*// suite("Auth", s => { s.test("login works", t => { t.equal(1, 1) }) })
fn suite(name, fn2) {
  val s = {
    name,
    tests:   [],
    _before: null,
    _after:  null
  }
  s.test   = (tName, tFn) => { s.tests.push({ name: tName, fn: tFn }) }
  s.before = (fn3) => { s._before = fn3 }
  s.after  = (fn3) => { s._after  = fn3 }
  _suites.push(s)
  fn2(s)
}

fn _formatTime(ms) {
  if (ms < 1000) { return ms + "ms" }
  return (ms / 1000).toFixed(2) + "s"
}

*// _runAll — called automatically via setImmediate after all suites are registered
async fn _runAll() {
  if (_running) { return }
  _running = true
  var totalPass = 0
  var totalFail = 0
  val startAll = Date.now()

  for val s of _suites {
    process.stdout.write("\n\n  " + colorize("bold", s.name) + "\n")
    var pass = 0
    var fail = 0
    if (s._before) { try { await s._before() } catch (e2) {} }
    for val t2 of s.tests {
      val start = Date.now()
      try {
        val result = t2.fn(assert)
        if (result && typeof result.then === "function") { await result }
        val ms = Date.now() - start
        process.stdout.write("    " + colorize("green", "✓") + " " + colorize("gray", t2.name + " (" + ms + "ms)") + "\n")
        pass++
      } catch (e) {
        val ms = Date.now() - start
        process.stdout.write("    " + colorize("red", "✗") + " " + t2.name + " (" + ms + "ms)\n")
        process.stdout.write("      " + colorize("red", e.message) + "\n")
        fail++
      }
    }
    if (s._after) { try { await s._after() } catch (e2) {} }
    val suiteTotal = pass + fail
    process.stdout.write("\n  " + colorize("green", pass + " passed") + "  " +
      (fail > 0 ? colorize("red", fail + " failed") + "  " : "") +
      colorize("gray", suiteTotal + " total") + "\n")
    totalPass += pass
    totalFail += fail
  }

  val elapsed = _formatTime(Date.now() - startAll)
  process.stdout.write("\n" + colorize("gray", "─".repeat(41)) + "\n")
  process.stdout.write("  " +
    colorize(totalFail > 0 ? "red" : "green", totalPass + " passed") + "  " +
    (totalFail > 0 ? colorize("red", totalFail + " failed") + "  " : "") +
    "  Finished in " + colorize("cyan", elapsed) + "\n\n"
  )
  if (totalFail > 0) { process.exitCode = 1 }
}

setImmediate(_runAll)

fn run() {
  *// run() is a no-op — suites run automatically via setImmediate
  *// kept for backwards compatibility
}

export { suite, assert, run }
