*// ntl:validate — Zod-style schema validation, zero dependencies
*// import it: val { object, string, number } = require("ntl:validate")
*//
*// val schema = object({ name: string().min(2), age: number().min(18) })
*// val result = schema.safeParse(input)   → { success: true, data } or { success: false, errors }

class ValidationError extends Error {
  init(message, errors) {
    super(message)
    this.name   = "ValidationError"
    this.errors = errors || []
  }
}

*// ─── Base Schema ──────────────────────────────────────────────────────

class Schema {
  init(typeName) {
    this._type     = typeName
    this._checks   = []
    this._optional = false
    this._nullable = false
    this._default  = undefined
  }

  optional()   { this._optional = true; return this }
  nullable()   { this._nullable = true; return this }

  default(v2) {
    this._default  = v2
    this._optional = true
    return this
  }

  _addCheck(fn2, message) {
    this._checks.push({ fn: fn2, message })
    return this
  }

  _coerce(v2) { return v2 }

  _validate(v2) {
    for val c of this._checks {
      if (!c.fn(v2)) { return { ok: false, message: c.message } }
    }
    return { ok: true }
  }

  parse(value) {
    if (value === undefined || value === null) {
      if (value === null && this._nullable) { return { success: true, data: null } }
      if (this._default !== undefined) { return { success: true, data: this._default } }
      if (this._optional) { return { success: true, data: undefined } }
      return { success: false, errors: [{ message: "Required" }] }
    }
    val coerced = this._coerce(value)
    val typeErr = this._typeCheck(coerced)
    if (typeErr) { return { success: false, errors: [{ message: typeErr }] } }
    val check = this._validate(coerced)
    if (!check.ok) { return { success: false, errors: [{ message: check.message }] } }
    return { success: true, data: coerced }
  }

  *// safeParse → { success: true, data } or { success: false, errors }
  safeParse(value) { return this.parse(value) }

  _typeCheck(v2) { return null }
}

*// ─── String ───────────────────────────────────────────────────────────

class StringSchema extends Schema {
  init() { super("string") }

  _coerce(v2) { return typeof v2 === "string" ? v2 : String(v2) }

  _typeCheck(v2) {
    if (typeof v2 !== "string") { return `Expected string, got ${typeof v2}` }
    return null
  }

  min(n)         { return this._addCheck(v2 => v2.length >= n,     `Min length ${n}`) }
  max(n)         { return this._addCheck(v2 => v2.length <= n,     `Max length ${n}`) }
  nonempty()     { return this._addCheck(v2 => v2.length > 0,      `Cannot be empty`) }
  email()        { return this._addCheck(v2 => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v2), `Invalid email`) }
  url()          { return this._addCheck(v2 => { try { new URL(v2); return true } catch(_e) { return false } }, `Invalid URL`) }
  regex(r)       { return this._addCheck(v2 => r.test(v2),         `Does not match ${r}`) }
  startsWith(p2) { return this._addCheck(v2 => v2.startsWith(p2),  `Must start with "${p2}"`) }
  endsWith(s2)   { return this._addCheck(v2 => v2.endsWith(s2),    `Must end with "${s2}"`) }
  oneOf(vals)    { return this._addCheck(v2 => vals.includes(v2),  `Must be one of: ${vals.join(", ")}`) }
}

*// ─── Number ───────────────────────────────────────────────────────────

class NumberSchema extends Schema {
  init() { super("number") }

  _coerce(v2) { return typeof v2 === "string" ? parseFloat(v2) : v2 }

  _typeCheck(v2) {
    if (typeof v2 !== "number" || isNaN(v2)) { return `Expected number, got ${typeof v2}` }
    return null
  }

  min(n)       { return this._addCheck(v2 => v2 >= n,                `Must be >= ${n}`) }
  max(n)       { return this._addCheck(v2 => v2 <= n,                `Must be <= ${n}`) }
  positive()   { return this._addCheck(v2 => v2 > 0,                 `Must be positive`) }
  negative()   { return this._addCheck(v2 => v2 < 0,                 `Must be negative`) }
  integer()    { return this._addCheck(v2 => Number.isInteger(v2),   `Must be integer`) }
  between(a, b){ return this._addCheck(v2 => v2 >= a && v2 <= b,     `Must be between ${a} and ${b}`) }
}

*// ─── Boolean ──────────────────────────────────────────────────────────

class BooleanSchema extends Schema {
  init() { super("boolean") }
  _coerce(v2) { return v2 === "true" ? true : v2 === "false" ? false : v2 }
  _typeCheck(v2) {
    if (typeof v2 !== "boolean") { return `Expected boolean, got ${typeof v2}` }
    return null
  }
}

*// ─── Array ────────────────────────────────────────────────────────────

class ArraySchema extends Schema {
  init(itemSchema) {
    super("array")
    this._item = itemSchema
  }

  _typeCheck(v2) {
    if (!Array.isArray(v2)) { return `Expected array, got ${typeof v2}` }
    return null
  }

  parse(value) {
    val base = super.parse(value)
    if (!base.success || !base.data) { return base }
    have this._item as item {
      val errors = []
      val data = base.data.map((v2, i) => {
        val r = item.parse(v2)
        if (!r.success) {
          for val e of r.errors { errors.push({ path: i, message: e.message }) }
          return v2
        }
        return r.data
      })
      if (errors.length > 0) { return { success: false, errors } }
      return { success: true, data }
    }
    return base
  }

  min(n)     { return this._addCheck(v2 => v2.length >= n, `At least ${n} items`) }
  max(n)     { return this._addCheck(v2 => v2.length <= n, `At most ${n} items`) }
  nonempty() { return this._addCheck(v2 => v2.length > 0,  `Cannot be empty`) }
}

*// ─── Object ───────────────────────────────────────────────────────────

class ObjectSchema extends Schema {
  init(shape) {
    super("object")
    this._shape  = shape || {}
  }

  _typeCheck(v2) {
    if (typeof v2 !== "object" || Array.isArray(v2) || v2 === null) {
      return `Expected object`
    }
    return null
  }

  parse(value) {
    val base = super.parse(value)
    if (!base.success || !base.data) { return base }
    val obj = base.data
    val result = {}
    val errors = []
    for val k of Object.keys(this._shape) {
      val r = this._shape[k].parse(obj[k])
      if (!r.success) {
        for val e of r.errors { errors.push({ path: k, message: e.message }) }
      } else {
        if (r.data !== undefined) { result[k] = r.data }
      }
    }
    if (errors.length > 0) { return { success: false, errors } }
    return { success: true, data: result }
  }
}

*// ─── Union / Literal ──────────────────────────────────────────────────

class UnionSchema extends Schema {
  init(schemas) {
    super("union")
    this._schemas = schemas
  }

  parse(value) {
    for val s of this._schemas {
      val r = s.parse(value)
      if (r.success) { return r }
    }
    return { success: false, errors: [{ message: "No union member matched" }] }
  }
}

*// ─── Factory functions (what the tests import) ────────────────────────
*// val { string, number, object } = require("ntl:validate")

fn string()       { return new StringSchema() }
fn number()       { return new NumberSchema() }
fn boolean()      { return new BooleanSchema() }
fn array(item)    { return new ArraySchema(item) }
fn object(shape)  { return new ObjectSchema(shape) }
fn union(schemas) { return new UnionSchema(schemas) }
fn literal(val2)  {
  val s = new Schema("literal")
  s._addCheck(v2 => v2 === val2, `Must equal ${JSON.stringify(val2)}`)
  return s
}

export {
  string, number, boolean, array, object, union, literal,
  ValidationError, Schema
}
